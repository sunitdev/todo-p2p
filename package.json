{
  "name": "todo-p2p",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b && bun --filter @todo-p2p/web typecheck",
    "lint": "eslint .",
    "test": "bun --filter '@todo-p2p/*' test",
    "test:e2e": "bun --filter @todo-p2p/web test:e2e",
    "hooks:install": "pre-commit install --install-hooks && pre-commit install --hook-type pre-push",
    "hooks:run": "pre-commit run --all-files"
  },
  "devDependencies": {
    "@eslint/js": "9.15.0",
    "@happy-dom/global-registrator": "15.11.7",
    "@playwright/test": "1.49.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/bun": "1.1.14",
    "eslint": "9.15.0",
    "happy-dom": "15.11.7",
    "typescript": "5.6.3",
    "typescript-eslint": "8.15.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
