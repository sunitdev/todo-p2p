{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "todo-p2p",
  "version": "0.0.0",
  "identifier": "com.todop2p.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun --filter @todo-p2p/web dev",
    "beforeBuildCommand": "bun --filter @todo-p2p/web build"
  },
  "app": {
    "windows": [
      { "label": "main", "title": "todo-p2p", "width": 1024, "height": 720, "resizable": true }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
