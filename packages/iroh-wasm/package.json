{
  "name": "@todo-p2p/iroh-wasm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser iroh transport (Rust -> wasm-bindgen). Built by scripts/build-wasm.sh into pkg/.",
  "main": "./pkg/todo_p2p_iroh_wasm.js",
  "module": "./pkg/todo_p2p_iroh_wasm.js",
